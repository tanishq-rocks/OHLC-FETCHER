{
  "name": "ohlc-fetcher",
  "version": "1.0.0",
  "description": "CLI and Node.js library to download historical OHLCV (Open/High/Low/Close/Volume) candle data for stocks, crypto, forex-adjacent instruments, ETFs, indices, and futures from Yahoo Finance, and export it to CSV, TSV, JSON, or NDJSON.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "ohlc-fetch": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js"
  },
  "keywords": [
    "ohlc",
    "ohlcv",
    "candlestick",
    "candle-data",
    "historical-data",
    "stock-data",
    "market-data",
    "financial-data",
    "yahoo-finance",
    "yahoo-finance2",
    "stocks",
    "crypto",
    "cryptocurrency",
    "forex",
    "trading",
    "backtesting",
    "quant",
    "quantitative-finance",
    "csv-export",
    "cli"
  ],
  "homepage": "https://github.com/tanishq-rocks/OHLC-FETCHER#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanishq-rocks/OHLC-FETCHER.git"
  },
  "bugs": {
    "url": "https://github.com/tanishq-rocks/OHLC-FETCHER/issues"
  },
  "author": "Tanishq Patni",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yahoo-finance2": "^3.15.4"
  }
}
